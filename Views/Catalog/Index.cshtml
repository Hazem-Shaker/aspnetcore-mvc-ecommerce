@model e_commerce.ViewModels.Catalog.ProductListVM
@{
    ViewData["Title"] = "Catalog";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Our Products</h2>
    <span class="text-muted">@Model.Products.TotalCount products found</span>
</div>

<div class="row">
    <div class="col-lg-3 mb-4">
        <div class="card filter-card shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold text-uppercase mb-3">Filters</h6>
                <form method="get" asp-action="Index">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Search</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/></svg>
                            </span>
                            <input type="text" name="q" value="@Model.SearchQuery" class="form-control" placeholder="Search..." />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Category</label>
                        <select name="categoryId" class="form-select">
                            <option value="">All Categories</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Sort By</label>
                        <select name="sort" class="form-select">
                            <option value="" selected="@(Model.SortBy == null)">Newest</option>
                            <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Price: Low to High</option>
                            <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Price: High to Low</option>
                            <option value="name" selected="@(Model.SortBy == "name")">Name</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-dark w-100">Apply Filters</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-9">
        @if (!Model.Products.Items.Any())
        {
            <div class="text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" viewBox="0 0 16 16" class="text-muted mb-3"><path d="M5.757 1.071a.5.5 0 0 1 .172.686L3.383 6h9.234L10.07 1.757a.5.5 0 1 1 .858-.514L13.783 6H15.5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5H.5a.5.5 0 0 1-.5-.5v-1A.5.5 0 0 1 .5 6h1.717L5.07 1.243a.5.5 0 0 1 .686-.172zM3.394 15l-1.48-6h-.97l1.525 6.426a.75.75 0 0 0 .729.574h9.606a.75.75 0 0 0 .73-.574L15.056 9h-.972l-1.479 6z"/></svg>
                <h5 class="text-muted">No products found</h5>
                <p class="text-muted">Try adjusting your filters or search terms.</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var product in Model.Products.Items)
                {
                    var image = product.Files.FirstOrDefault(f => f.Type == "image");
                    <div class="col">
                        <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                            <div class="card product-card h-100 shadow-sm">
                                @if (image != null)
                                {
                                    <img src="@image.Path" class="card-img-top" alt="@product.Name" />
                                }
                                else
                                {
                                    <div class="placeholder-img">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16" class="text-muted opacity-50"><path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/><path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z"/></svg>
                                    </div>
                                }
                                <div class="card-body d-flex flex-column">
                                    <span class="product-category mb-1">@product.Category.Name</span>
                                    <h6 class="card-title text-dark mb-2">@product.Name</h6>
                                    <div class="d-flex justify-content-between align-items-center mt-auto">
                                        <span class="product-price">$@product.Price.ToString("F2")</span>
                                        @if (product.Stock > 0)
                                        {
                                            <span class="badge bg-success-subtle text-success badge-stock">In Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger badge-stock">Sold Out</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
            <div class="mt-4">
                <partial name="_Pagination" model="Model.Products" />
            </div>
        }
    </div>
</div>
