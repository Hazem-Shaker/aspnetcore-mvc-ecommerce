@model e_commerce.ViewModels.Catalog.ProductDetailsVM
@{
    ViewData["Title"] = Model.Product.Name;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index" class="text-decoration-none">Catalog</a></li>
        <li class="breadcrumb-item"><span>@Model.Product.Category.Name</span></li>
        <li class="breadcrumb-item active">@Model.Product.Name</li>
    </ol>
</nav>

<div class="row g-5">
    <div class="col-lg-6">
        @if (Model.Images.Any())
        {
            <div id="productCarousel" class="carousel slide rounded-4 overflow-hidden shadow" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Images.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="@Model.Images[i].Path" class="d-block w-100" alt="@Model.Product.Name" style="height: 450px; object-fit: cover;" />
                        </div>
                    }
                </div>
                @if (Model.Images.Count > 1)
                {
                    <div class="carousel-indicators">
                        @for (int i = 0; i < Model.Images.Count; i++)
                        {
                            <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="bg-light rounded-4 d-flex align-items-center justify-content-center shadow-sm" style="height: 450px;">
                <div class="text-center text-muted">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" viewBox="0 0 16 16" class="opacity-50"><path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/><path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z"/></svg>
                    <p class="mt-2">No Image Available</p>
                </div>
            </div>
        }
    </div>
    <div class="col-lg-6">
        <span class="badge bg-secondary mb-2">@Model.Product.Category.Name</span>
        <h2 class="fw-bold mb-3">@Model.Product.Name</h2>
        <h3 class="text-primary fw-bold mb-4">$@Model.Product.Price.ToString("F2")</h3>
        <p class="text-muted mb-4 lh-lg">@Model.Product.Description</p>

        <div class="mb-4">
            @if (Model.Product.Stock > 0)
            {
                <span class="badge bg-success-subtle text-success badge-stock fs-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
                    In Stock (@Model.Product.Stock available)
                </span>
            }
            else
            {
                <span class="badge bg-danger-subtle text-danger badge-stock fs-6">Out of Stock</span>
            }
        </div>

        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer") && Model.Product.Stock > 0)
        {
            <form asp-controller="Cart" asp-action="Add" method="post" class="mb-3">
                <input type="hidden" name="productId" value="@Model.Product.Id" />
                <button type="submit" class="btn btn-primary btn-lg px-5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" class="me-2 mb-1"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                    Add to Cart
                </button>
            </form>
        }

        <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1 mb-1"><path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/></svg>
            Back to Catalog
        </a>
    </div>
</div>
