@model e_commerce.ViewModels.Orders.OrderListVM
@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex align-items-center mb-4">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" class="me-2 text-primary"><path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2z"/><path d="M5 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 5 8m0-2.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5m0 5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5m-1-5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0M4 8a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0m0 2.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0"/></svg>
    <h2 class="mb-0">My Orders</h2>
</div>

@if (!Model.Orders.Items.Any())
{
    <div class="text-center py-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" viewBox="0 0 16 16" class="text-muted opacity-50 mb-3"><path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2z"/></svg>
        <h5 class="text-muted">No orders yet</h5>
        <p class="text-muted mb-4">Your order history will appear here once you place your first order.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Start Shopping</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4">Order #</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="pe-4"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders.Items)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">#@order.Id</td>
                            <td class="text-muted">@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>@order.Items.Count items</td>
                            <td class="fw-bold text-primary">$@order.TotalAmount.ToString("F2")</td>
                            <td>
                                @{
                                    var badgeClass = order.Status switch
                                    {
                                        "Pending" => "bg-warning-subtle text-warning-emphasis",
                                        "Processing" => "bg-info-subtle text-info-emphasis",
                                        "Shipped" => "bg-primary-subtle text-primary-emphasis",
                                        "Delivered" => "bg-success-subtle text-success-emphasis",
                                        "Cancelled" => "bg-danger-subtle text-danger-emphasis",
                                        _ => "bg-secondary-subtle text-secondary-emphasis"
                                    };
                                }
                                <span class="badge status-badge @badgeClass">@order.Status</span>
                            </td>
                            <td class="pe-4">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-4">
        <partial name="_Pagination" model="Model.Orders" />
    </div>
}
