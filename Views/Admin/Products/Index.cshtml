@model List<e_commerce.Models.Product>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Products</h2>
    <a asp-action="Create" class="btn btn-primary">Add Product</a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                var image = p.Files.FirstOrDefault(f => f.Type == "image");
                <tr>
                    <td>
                        @if (image != null)
                        {
                            <img src="@image.Path" alt="@p.Name" class="rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>@p.Name</td>
                    <td>@p.Category.Name</td>
                    <td>$@p.Price.ToString("F2")</td>
                    <td>@p.Stock</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
