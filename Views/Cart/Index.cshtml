@model e_commerce.ViewModels.Cart.CartVM
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="d-flex align-items-center mb-4">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" class="me-2 text-primary">
        <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
    </svg>
    <h2 class="mb-0">Shopping Cart</h2>
</div>

@if (!Model.Items.Any())
{
    <div class="text-center py-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" viewBox="0 0 16 16" class="text-muted opacity-50 mb-3">
            <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
        </svg>
        <h5 class="text-muted">Your cart is empty</h5>
        <p class="text-muted mb-4">Looks like you haven't added anything yet.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Browse Products</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4">Product</th>
                        <th>Price</th>
                        <th style="width: 160px;">Quantity</th>
                        <th>Subtotal</th>
                        <th class="pe-4"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (item.ImagePath != null)
                                    {
                                        <img src="@item.ImagePath" alt="@item.ProductName" class="cart-img me-3" />
                                    }
                                    <span class="fw-semibold">@item.ProductName</span>
                                </div>
                            </td>
                            <td class="text-muted">$@item.UnitPrice.ToString("F2")</td>
                            <td>
                                <form asp-action="Update" method="post" class="d-flex align-items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="btn btn-outline-secondary qty-btn" @(item.Quantity <= 1 ? "disabled" : "")>-</button>
                                    <span class="fw-semibold" style="min-width: 24px; text-align: center;">@item.Quantity</span>
                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="btn btn-outline-secondary qty-btn" @(item.Quantity >= item.Stock ? "disabled" : "")>+</button>
                                </form>
                            </td>
                            <td class="fw-bold text-primary">$@item.Subtotal.ToString("F2")</td>
                            <td class="pe-4">
                                <form asp-action="Remove" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light border-0 p-4">
            <div class="d-flex justify-content-between align-items-center">
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1 mb-1"><path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/></svg>
                    Continue Shopping
                </a>
                <div class="d-flex align-items-center gap-4">
                    <div class="text-end">
                        <span class="text-muted d-block">Total</span>
                        <span class="fs-4 fw-bold text-primary">$@Model.Total.ToString("F2")</span>
                    </div>
                    <a asp-controller="Orders" asp-action="Checkout" class="btn btn-primary btn-lg px-4">
                        Proceed to Checkout
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="ms-2 mb-1"><path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
